# PostgreSQL overlay database (Prisma)
DATABASE_URL="postgresql://uchiyomi:uchiyomi@localhost:5433/uchiyomi?schema=public"

# Session sealing secret for nuxt-auth-utils (>= 32 chars), keep out of the repo
NUXT_SESSION_PASSWORD=""

# Integration tests connect to a separate database on the same server
TEST_DATABASE_URL="postgresql://uchiyomi:uchiyomi@localhost:5433/uchiyomi_test?schema=public"

# Headless Suwayomi engine base URL (ADR-0001). Internal engine; the app is the
# only client. Locally it is the docker-compose service published on 4567.
SUWAYOMI_URL="http://localhost:4567"
