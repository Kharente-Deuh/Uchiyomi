{
  "name": "uchiyomi",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "description": "Self-hosted manga & webtoon server with a modern PWA, built on Suwayomi.",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:pwa": "VITE_PLUGIN_PWA=true nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "prisma generate && nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "up": "taze major -I",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@iconify/vue": "catalog:frontend",
    "@prisma/adapter-pg": "catalog:db",
    "@prisma/client": "catalog:db",
    "@vueuse/core": "catalog:frontend",
    "pg": "catalog:db",
    "pinia": "catalog:frontend",
    "vue": "catalog:frontend",
    "vuetify": "catalog:frontend"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@commitlint/cli": "catalog:dev",
    "@commitlint/config-conventional": "catalog:dev",
    "@commitlint/types": "catalog:dev",
    "@iconify-json/fa6-regular": "catalog:dev",
    "@iconify-json/fa6-solid": "catalog:dev",
    "@nuxt/eslint": "catalog:build",
    "@nuxt/test-utils": "catalog:dev",
    "@nuxtjs/i18n": "catalog:build",
    "@pinia/nuxt": "catalog:build",
    "@types/node": "catalog:dev",
    "@types/pg": "catalog:dev",
    "@vite-pwa/nuxt": "catalog:build",
    "@vue/test-utils": "catalog:dev",
    "@vueuse/nuxt": "catalog:build",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "happy-dom": "catalog:dev",
    "husky": "catalog:dev",
    "knip": "catalog:dev",
    "nuxt": "catalog:build",
    "prisma": "catalog:db",
    "sass-embedded": "catalog:dev",
    "taze": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev",
    "vue-tsc": "catalog:dev",
    "vuetify-nuxt-module": "catalog:build"
  }
}
