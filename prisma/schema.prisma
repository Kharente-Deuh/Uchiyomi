// Uchiyomi per-user overlay (ADR-0004). Suwayomi integer IDs are referenced
// without FK; (sourceId, mangaUrl) is a natural-key fallback.

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: the connection URL lives in prisma.config.ts (for Migrate/CLI);
  // the runtime client connects via the `pg` driver adapter (server/utils/prisma.ts).
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AuthProvider {
  LOCAL
  OIDC
}

enum SeriesType {
  MANGA
  WEBTOON
  COMIC
}

enum SeriesStatus {
  ONGOING
  COMPLETED
  HIATUS
  UNKNOWN
}

enum LibraryStatus {
  READING
  STOPPED
}

enum ReadingMode {
  PAGED
  LONG_STRIP
}

enum ReadingDirection {
  LTR
  RTL
}

enum DownloadStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum DownloadPriority {
  NEW_CHAPTER
  BACKFILL
}

enum ExtensionHealth {
  OK
  ERROR
}

model AppUser {
  id                  String   @id @default(cuid())
  accountName         String   @unique @map("account_name")
  displayName         String   @map("display_name")
  role                Role     @default(USER)
  status              UserStatus @default(ACTIVE)
  canManageExtensions Boolean  @default(false) @map("can_manage_extensions")
  canDownload         Boolean  @default(false) @map("can_download")
  allowNsfw           Boolean  @default(false) @map("allow_nsfw")
  showNsfw            Boolean  @default(false) @map("show_nsfw")
  createdAt           DateTime @default(now()) @map("created_at")

  identities          AuthIdentity[]
  sessions            Session[]
  subscriptions       Subscription[]
  categories          Category[]
  readingProgress     ReadingProgress[]
  readingPreferences  UserReadingPreference[]
  installedExtensions Extension[]             @relation("InstalledExtensions")
  downloadJobs        DownloadJob[]           @relation("RequestedDownloads")

  @@map("app_user")
}

model AuthIdentity {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  provider     AuthProvider
  subject      String
  passwordHash String?      @map("password_hash")
  createdAt    DateTime     @default(now()) @map("created_at")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([userId])
  @@map("auth_identity")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  userAgent String?  @map("user_agent")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Invite {
  id              String    @id @default(cuid())
  code            String    @unique
  role            Role      @default(USER)
  createdByUserId String?   @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  expiresAt       DateTime? @map("expires_at")
  acceptedAt      DateTime? @map("accepted_at")

  @@map("invite")
}

model Subscription {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  seriesId  String        @map("series_id")
  status    LibraryStatus @default(READING)
  createdAt DateTime      @default(now()) @map("created_at")

  user       AppUser                @relation(fields: [userId], references: [id], onDelete: Cascade)
  series     Series                 @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  categories SubscriptionCategory[]

  @@unique([userId, seriesId])
  @@index([userId])
  @@index([seriesId])
  @@map("subscription")
}

model Category {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String
  order  Int    @default(0)

  user          AppUser                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions SubscriptionCategory[]

  @@unique([userId, name])
  @@index([userId])
  @@map("category")
}

model SubscriptionCategory {
  subscriptionId String @map("subscription_id")
  categoryId     String @map("category_id")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([subscriptionId, categoryId])
  @@index([categoryId])
  @@map("subscription_category")
}

model ReadingProgress {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  chapterId String   @map("chapter_id")
  lastPage  Int      @default(0) @map("last_page")
  pageCount Int      @default(0) @map("page_count")
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  user    AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@map("reading_progress")
}

model Extension {
  id                  String          @id @default(cuid())
  pkgName             String          @unique @map("pkg_name")
  name                String
  lang                String
  iconUrl             String?         @map("icon_url")
  isNsfw              Boolean         @default(false) @map("is_nsfw")
  installedByUserId   String?         @map("installed_by_user_id")
  installedAt         DateTime        @default(now()) @map("installed_at")
  health              ExtensionHealth @default(OK)
  consecutiveFailures Int             @default(0) @map("consecutive_failures")
  lastErrorAt         DateTime?       @map("last_error_at")
  lastErrorMessage    String?         @map("last_error_message")

  installedBy AppUser?          @relation("InstalledExtensions", fields: [installedByUserId], references: [id], onDelete: SetNull)
  errors      ExtensionErrorLog[]
  sources     Source[]

  @@index([installedByUserId])
  @@map("extension")
}

model ExtensionErrorLog {
  id          String   @id @default(cuid())
  extensionId String   @map("extension_id")
  occurredAt  DateTime @default(now()) @map("occurred_at")
  message     String
  context     String?

  extension Extension @relation(fields: [extensionId], references: [id], onDelete: Cascade)

  @@index([extensionId, occurredAt])
  @@map("extension_error_log")
}

model Source {
  id             String  @id
  pkgName        String  @map("pkg_name")
  name           String
  lang           String
  isNsfw         Boolean @default(false) @map("is_nsfw")
  isConfigurable Boolean @default(false) @map("is_configurable")
  isEnabled      Boolean @default(true) @map("is_enabled")

  extension Extension @relation(fields: [pkgName], references: [pkgName], onDelete: Cascade)

  @@index([pkgName])
  @@map("source")
}

model Series {
  id                String       @id @default(cuid())
  mangaId           Int          @map("manga_id")
  sourceId          String       @map("source_id")
  mangaUrl          String       @map("manga_url")
  title             String
  thumbnailUrl      String?      @map("thumbnail_url")
  type              SeriesType
  typeSetByUserId   String?      @map("type_set_by_user_id")
  status            SeriesStatus @default(UNKNOWN)
  lastChapterAt     DateTime?    @map("last_chapter_at")
  lastChapterNumber Float?       @map("last_chapter_number")
  resumedAt         DateTime?    @map("resumed_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  chapters      Chapter[]
  subscriptions Subscription[]
  downloadJobs  DownloadJob[]

  @@unique([mangaId, sourceId])
  @@index([lastChapterAt])
  @@index([type])
  @@index([status])
  @@map("series")
}

model Chapter {
  id         String   @id @default(cuid())
  chapterId  Int      @map("chapter_id")
  seriesId   String   @map("series_id")
  number     Float
  name       String
  scanlator  String?
  uploadedAt DateTime @map("uploaded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  series          Series            @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  readingProgress ReadingProgress[]
  downloadJob     DownloadJob?

  @@unique([seriesId, chapterId])
  @@index([seriesId, uploadedAt])
  @@map("chapter")
}

model UserReadingPreference {
  userId    String           @map("user_id")
  type      SeriesType
  mode      ReadingMode
  direction ReadingDirection

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, type])
  @@map("user_reading_preference")
}

model DownloadJob {
  id                String           @id @default(cuid())
  chapterId         String           @map("chapter_id")
  seriesId          String           @map("series_id")
  status            DownloadStatus   @default(PENDING)
  priority          DownloadPriority @default(BACKFILL)
  attempts          Int              @default(0)
  lastError         String?          @map("last_error")
  requestedByUserId String?          @map("requested_by_user_id")
  nextAttemptAt     DateTime?        @map("next_attempt_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  series      Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  requestedBy AppUser? @relation("RequestedDownloads", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@unique([chapterId])
  @@index([status, priority, createdAt])
  @@index([seriesId])
  @@map("download_job")
}
