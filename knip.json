{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "vuetify.config.ts",
    "i18n/i18n.config.ts",
    "app/pages/**/*.vue",
    "app/layouts/**/*.vue",
    "app/components/**/*.vue",
    "app/plugins/**/*.ts",
    "server/**/*.ts"
  ],
  "project": [
    "**/*.{ts,vue}"
  ],
  "ignoreDependencies": [
    "@prisma/client",
    "@types/pg",
    "@vueuse/core",
    "eslint-formatter-checkstyle",
    "ofetch",
    "pg",
    "sass-embedded",
    "vitest-environment-nuxt",
    "vue-i18n",
    "vue-router",
    "vue-tsc"
  ]
}
