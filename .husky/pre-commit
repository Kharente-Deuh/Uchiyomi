staged=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '\.(ts|tsx|js|mjs|cts|mts|vue|scss|css)$' \
  | grep -vE '(^|/)(node_modules|\.nuxt|dist|coverage)/|prisma/generated/' || true)
[ -z "$staged" ] && exit 0
echo "$staged" | xargs bash scripts/ensure-license-header.sh
echo "$staged" | xargs git add
